# ─── PostgreSQL ───────────────────────────────
POSTGRES_DB=lumus
POSTGRES_USER=lumus_user
POSTGRES_PASSWORD=change_me_in_production

# ─── Application ──────────────────────────────
DATABASE_URL=postgresql://lumus_user:change_me_in_production@postgres:5432/lumus
NODE_ENV=development
PORT=3000
MEMORY_SERVICE_URL=http://memory-service:8010

# ─── LLM ──────────────────────────────────────
LLM_PROVIDER=ollama
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma:2b
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── pgAdmin ──────────────────────────────────
PGADMIN_EMAIL=admin@lumos.dev
PGADMIN_PASSWORD=change_me_in_production
